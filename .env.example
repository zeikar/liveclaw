# OpenClaw (main process)
# Rarely needed: the gateway token and base URL are auto-detected from
# ~/.openclaw/openclaw.json at runtime. Only set these to override a dev gateway
# auto-detection can't see (a non-default OPENCLAW_CONFIG_PATH, a CLI --port, etc).
# Requires the gateway's OpenAI-compatible endpoint, which is off by default:
#   openclaw config set gateway.http.endpoints.chatCompletions.enabled true
OPENCLAW_TOKEN=
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1

# Direct OpenAI TTS from renderer (local/dev only)
# VITE_OPENAI_* names still work as legacy fallbacks.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
