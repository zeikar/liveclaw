# OpenClaw (main process)
# Requires the gateway's OpenAI-compatible endpoint, which is off by default:
#   openclaw config set gateway.http.endpoints.chatCompletions.enabled true
OPENCLAW_TOKEN=
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1

# Direct OpenAI TTS from renderer (local/dev only)
VITE_OPENAI_API_KEY=
VITE_OPENAI_TTS_MODEL=gpt-4o-mini-tts
VITE_OPENAI_TTS_VOICE=marin
